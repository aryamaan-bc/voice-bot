# Basic Capital FAQ Voice Agent — environment variables
# Copy to .env and fill in. Never commit .env to version control.

# ─── Demo mode ─────────────────────────────────────────────────────────────
# Set to "true" for a browser-based demo with no telephony infrastructure.
# In demo mode:
#   - `escalate_to_human` skips Twilio entirely; it sleeps briefly then
#     returns "unavailable", so the flow falls through to the email
#     fallback (Linear is also optional in demo mode — if LINEAR_API_KEY
#     is unset, the bot tells the caller to email support).
#   - Only GEMINI_API_KEY is strictly required.
#   - Everything else below (Twilio, Slack, Linear, cell numbers) can be
#     left blank.
# Set to "false" (or unset) for real production behavior.
DEMO_MODE=true

# ─── LLM: Anthropic Claude Haiku 4.5 ──────────────────────────────────────
# Get a key at https://console.anthropic.com (Settings → API Keys).
# Starts with `sk-ant-`. New accounts get $5 free credit.
# To switch to Gemini instead, change main.py's model line to
# "gemini/gemini-2.5-flash" and use GEMINI_API_KEY (key from
# https://aistudio.google.com).
ANTHROPIC_API_KEY=

# ─── Twilio (telephony) ────────────────────────────────────────────────────
# Account SID + auth token from console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Your main Basic Capital Twilio number — used as caller ID on outbound probe
# calls so Taylor/Aryamaan see "Basic Capital" on their phones. E.164 format.
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# A second Twilio number that, when dialed, joins the caller into the shared
# conference room (configure its voice webhook to point at a TwiML Bin with
# `<Response><Dial><Conference>bc-active</Conference></Dial></Response>`).
# This is the number Line's `transfer_call` tool transfers the caller to.
CONFERENCE_JOIN_NUMBER=+1XXXXXXXXXX

# Conference room names are now derived per-call from the caller's phone
# number (see `_derive_conf_name` in escalation.py — both the Python probe
# code and the Twilio conference-join Function compute the same name from
# the same input). No env var needed. Edge case: same caller dialing twice
# within the probe window will still collide; rare enough to accept for v1.

# ─── Escalation targets (the hunt group — Taylor + Aryamaan) ───────────────
# Cell numbers to ring when the bot escalates. E.164 format. Probe calls dial
# both simultaneously; first to answer wins.
TAYLOR_CELL=+1XXXXXXXXXX
ARYAMAAN_CELL=+1XXXXXXXXXX

# ─── Slack (live alerts + callback tickets + post-call summaries) ─────────
# Incoming webhook URL from api.slack.com/apps → Incoming Webhooks. Bind it
# either to a channel (e.g. #bc-support) OR to your own DM — pick whichever
# in the "Add to workspace" channel picker.
#
# All message types go through this URL:
#   1. Live-call ping (fired when bot escalates — heads-up the team)
#   2. Callback/email log (fired when record_followup runs)
#   3. Post-call summary (fired when call ends, alongside Linear ticket)
# Without this URL, the bot still works — it just won't notify Slack.
SLACK_WEBHOOK_URL=

# ─── Linear (per-call tickets for ops team tracking) ──────────────────────
# Personal API key from linear.app/settings/api — starts with `lin_api_`.
# NOTE: Linear's auth header is `Authorization: lin_api_xxx` with NO Bearer
# prefix. The code handles this — paste the raw key here.
LINEAR_API_KEY=

# Team UUID for the team that should receive call tickets. Find via:
#   curl -s -H "Authorization: $LINEAR_API_KEY" \
#        -H "Content-Type: application/json" \
#        -d '{"query":"{teams{nodes{id name key}}}"}' \
#        https://api.linear.app/graphql | python3 -m json.tool
# Pick the team's `id` (the UUID, not the `key`).
LINEAR_TEAM_ID=

# Cartesia agent ID — used to build a clickable "audio + transcript" link
# in the Linear ticket and Slack summary so the ops team can jump straight
# to the recording. Find this in cartesia.toml or .cartesia/config.toml.
# Example: agent_CicivQhXS56dgUehm3B1Ea
CARTESIA_AGENT_ID=

# ─── Twilio Functions Service domain ──────────────────────────────────────
# Hostname (no protocol, no path) of the deployed Twilio Function Service
# that hosts /conference-join, /recording-callback, and /probe-accept.
# Used by escalation.py to build the press-1 gather-action URL embedded
# in probe outbound TwiML. Without this set, the probe falls back to
# direct conference join (works, but loses the voicemail-filter benefit
# of the press-1 gate).
# Example: bc-voice-functions-1234.twil.io
TWILIO_FUNCTIONS_DOMAIN=

# ─── Business hours ────────────────────────────────────────────────────────
# Outside these hours, the bot plays a closed-hours message and hangs up
# without engaging the LLM or ringing Taylor/Aryamaan. Defaults:
#   BUSINESS_HOURS_TZ=America/New_York
#   BUSINESS_HOURS_START_HOUR=9   (9 AM)
#   BUSINESS_HOURS_END_HOUR=19    (7 PM)
#   BUSINESS_HOURS_WEEKDAYS_ONLY=true  (Mon–Fri only)
# Override only if you want different hours — otherwise leave these unset.
BUSINESS_HOURS_TZ=America/New_York
BUSINESS_HOURS_START_HOUR=9
BUSINESS_HOURS_END_HOUR=19
BUSINESS_HOURS_WEEKDAYS_ONLY=true
