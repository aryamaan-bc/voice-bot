# Basic Capital FAQ Voice Agent — environment variables
# Copy to .env and fill in. Never commit .env to version control.

# ─── Demo mode ─────────────────────────────────────────────────────────────
# Set to "true" for a browser-based demo with no telephony infrastructure.
# In demo mode:
#   - `escalate_to_human` skips Twilio entirely; it sleeps briefly then
#     returns "unavailable", so the flow falls through to the email
#     fallback (Linear is also optional in demo mode — if LINEAR_API_KEY
#     is unset, the bot tells the caller to email support).
#   - Only GEMINI_API_KEY is strictly required.
#   - Everything else below (Twilio, Slack, Linear, cell numbers) can be
#     left blank.
# Set to "false" (or unset) for real production behavior.
DEMO_MODE=true

# ─── LLM: Google Gemini 2.5 Flash (free tier, via AI Studio) ───────────────
# Get a key at https://aistudio.google.com — free tier is generous enough
# for MVP testing and early production. No credit card required.
# To switch to Anthropic Claude Haiku instead, change main.py's model line
# back to "anthropic/claude-haiku-4-5" and use ANTHROPIC_API_KEY.
GEMINI_API_KEY=

# ─── Twilio (telephony) ────────────────────────────────────────────────────
# Account SID + auth token from console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Your main Basic Capital Twilio number — used as caller ID on outbound probe
# calls so Taylor/Aryamaan see "Basic Capital" on their phones. E.164 format.
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# A second Twilio number that, when dialed, joins the caller into the shared
# conference room (configure its voice webhook to point at a TwiML Bin with
# `<Response><Dial><Conference>bc-active</Conference></Dial></Response>`).
# This is the number Line's `transfer_call` tool transfers the caller to.
CONFERENCE_JOIN_NUMBER=+1XXXXXXXXXX

# Conference room name. One room shared across the deploy — if two callers
# escalate simultaneously they'd both land in the same room (known MVP wart,
# acceptable at BC's expected call volume).
CONFERENCE_NAME=bc-active

# ─── Escalation targets (the hunt group — Taylor + Aryamaan) ───────────────
# Cell numbers to ring when the bot escalates. E.164 format. Probe calls dial
# both simultaneously; first to answer wins.
TAYLOR_CELL=+1XXXXXXXXXX
ARYAMAAN_CELL=+1XXXXXXXXXX

# ─── Slack (incoming-call pings to the support team) ───────────────────────
# Incoming webhook URL from api.slack.com/apps → Incoming Webhooks, added to
# #bc-support channel (create the channel first).
SLACK_WEBHOOK_URL=

# ─── Linear (callback tickets when nobody picks up) ────────────────────────
# Personal API key from linear.app/settings/api — starts with `lin_api_`.
# NOTE: Linear's auth header is `Authorization: lin_api_xxx` with NO Bearer
# prefix. The code handles this correctly — just paste the raw key here.
LINEAR_API_KEY=

# Team UUID for the team that should receive callback tickets. Find via:
#   curl -H "Authorization: $LINEAR_API_KEY" \
#        -H "Content-Type: application/json" \
#        -d '{"query":"{teams{nodes{id name}}}"}' \
#        https://api.linear.app/graphql
LINEAR_TEAM_ID=

# ─── Business hours ────────────────────────────────────────────────────────
# Outside these hours, the bot plays a closed-hours message and hangs up
# without engaging the LLM or ringing Taylor/Aryamaan. Defaults:
#   BUSINESS_HOURS_TZ=America/New_York
#   BUSINESS_HOURS_START_HOUR=9   (9 AM)
#   BUSINESS_HOURS_END_HOUR=19    (7 PM)
#   BUSINESS_HOURS_WEEKDAYS_ONLY=true  (Mon–Fri only)
# Override only if you want different hours — otherwise leave these unset.
BUSINESS_HOURS_TZ=America/New_York
BUSINESS_HOURS_START_HOUR=9
BUSINESS_HOURS_END_HOUR=19
BUSINESS_HOURS_WEEKDAYS_ONLY=true
